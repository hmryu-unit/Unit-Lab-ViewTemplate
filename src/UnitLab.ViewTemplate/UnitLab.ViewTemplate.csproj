<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <LangVersion>latest</LangVersion>
    <PlatformTarget>x64</PlatformTarget>
    <UseWPF>true</UseWPF>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>UnitLab.ViewTemplate</RootNamespace>
    <AssemblyName>UnitLab.ViewTemplate</AssemblyName>
    <RevitVersion>2026</RevitVersion>
    <DeployRevitAddin>true</DeployRevitAddin>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Chuongmep.Revit.Api.RevitAPI" Version="2026.0.0" />
    <PackageReference Include="Chuongmep.Revit.Api.RevitAPIUI" Version="2026.0.0" />
    <PackageReference Include="Nice3point.Revit.Build.Tasks" Version="3.0.1" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\Presets\**\*.json" Link="Presets\%(RecursiveDir)%(Filename)%(Extension)">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
